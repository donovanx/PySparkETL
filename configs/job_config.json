    "debug_mode": true
  },
  "paths": {
    "bronze": "data/bronze/",
    "silver": "data/silver/",
    "raw": "data/raw/"
  },
  "spark": {
    "shuffle_partitions": 4,
    "sql_adaptive_enabled": true
  }
}
